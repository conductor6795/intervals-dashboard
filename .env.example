# Intervals.icu Konfiguration
# Athleten-ID aus der intervals.icu URL (z.B. i12345)
INTERVALS_ATHLETE_ID=i307717
# Client-seitig zugänglich (für Links aus dem Browser heraus)
NEXT_PUBLIC_INTERVALS_ATHLETE_ID=i307717

# API-Key aus intervals.icu → Einstellungen → API
INTERVALS_API_KEY=536fx2bti3gd6a3b7bkcbcr8l

# Optionaler Anzeigename
ATHLETE_NAME=Mein Name

# ── Notion-Sync (optional) ──────────────────────────────────────────────────
# Habits werden beim "→ intervals.icu"-Sync automatisch auch nach Notion
# geschoben (serverseitig via /api/notion-sync). Leer lassen = Notion-Sync aus.
# Integration-Token: https://www.notion.so/my-integrations  (ntn_...)
NOTION_HABITS_TOKEN=
# Datenbank-ID der Notion-Habits-Tabelle (mit der Integration teilen!)
NOTION_DB_ID=
